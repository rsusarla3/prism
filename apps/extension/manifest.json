{
  "manifest_version": 3,
  "name": "Prism",
  "version": "0.4.1",
  "description": "Summarize, quiz, visualize, hear, and find key terms on the page you're viewing.",
  "permissions": ["sidePanel", "storage", "contextMenus", "activeTab", "scripting"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": { "service_worker": "background.js", "type": "module" },
  "side_panel": { "default_path": "sidepanel.html" },
  "action": { "default_title": "Open Prism" },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
