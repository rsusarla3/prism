# Copy to .env at the repo root. .env is gitignored — never commit real keys.
# Loaded automatically by `npm run dev` (node --env-file-if-exists=.env).
# Only POST /api/generate needs these; every other route works without them.

GEMINI_API_KEY=
# Optional. Overrides the default model id.
GEMINI_MODEL=

# Optional. POST /api/generate/media uses the same key to synthesize narration.
# GEMINI_SPEECH_MODEL overrides the TTS model id, GEMINI_VOICE the prebuilt voice.
GEMINI_SPEECH_MODEL=
GEMINI_VOICE=
