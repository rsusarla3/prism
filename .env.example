# Copy to .env at the repo root. .env is gitignored — never commit real keys.
# Loaded automatically by `npm run dev` (node --env-file-if-exists=.env).
# Generation routes use one server-side provider; every other route works without one.

# Hosted Gemini option. Never place this key in the extension.
GEMINI_API_KEY=
# Optional. When blank, Prism uses Gemini 2.5 Flash.
GEMINI_MODEL=

# OpenAI-compatible option (including a local Ollama server).
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=

# Optional SQLite location. Defaults to data/prism.sqlite.
PRISM_DB_PATH=data/prism.sqlite
